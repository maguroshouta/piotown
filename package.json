{
  "name": "piotown",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "db:migrate:create": "prisma migrate dev",
    "db:migrate:turso": "for f in prisma/migrations/*/migration.sql; do echo \"Applying $f\"; turso db shell pionero < \"$f\"; done"
  },
